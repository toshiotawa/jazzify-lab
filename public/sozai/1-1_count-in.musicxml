      <note-size type="cue">75</note-size>
      <distance type="hyphen">60</distance>
      <distance type="beam">7.5</distance>
    </appearance>
    <music-font font-family="Maestro,engraved" font-size="19.7"/>
    <word-font font-family="ＭＳ 明朝" font-size="9.8"/>
  </defaults>
  <credit page="1">
