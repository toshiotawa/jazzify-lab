# Cloudflare R2 / Wrangler 用テンプレート
# いずれかのファイル名でルートに置く（Git 対象外）:
#   • `.env.r2`（推奨）
#   • `env.r2`（ドットなしでもスクリプトが読む）
# wrangler の R2 操作は `CLOUDFLARE_ACCOUNT_ID` が必要。
# `npm run wrangler:r2` は `.env.r2` / `env.r2` の `CF_ACCOUNT_ID` を環境変数に写す。

# 非対話環境（Cursor のエージェントターミナル、CI 等）で Wrangler を使う場合:
# CLOUDFLARE_API_TOKEN=...  （Account → API Tokens。R2 編集権限を含むトークン）
# https://developers.cloudflare.com/fundamentals/api/get-started/create-token/

CF_ACCOUNT_ID=
R2_BUCKET=jazzify-assets

# --s3 モード（S3 互換 API。非対話でも利用可）
# CF_ACCESS_KEY=
# CF_SECRET_KEY=
# の代わりに次でも可: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY または R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY

# 形式の参考: env.r2.mock（ダミー値のみ）
