# Jazz Learning Game - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ===== Stripe Configuration =====
# Stripe Publishable Key (starts with pk_test_ or pk_live_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Price IDs - Create these in Stripe Dashboard
# Standard Plan
VITE_STRIPE_STANDARD_MONTHLY_PRICE_ID=price_standard_monthly_id_here
VITE_STRIPE_STANDARD_YEARLY_PRICE_ID=price_standard_yearly_id_here

# Premium Plan  
VITE_STRIPE_PREMIUM_MONTHLY_PRICE_ID=price_premium_monthly_id_here
VITE_STRIPE_PREMIUM_YEARLY_PRICE_ID=price_premium_yearly_id_here

# Platinum Plan
VITE_STRIPE_PLATINUM_MONTHLY_PRICE_ID=price_platinum_monthly_id_here
VITE_STRIPE_PLATINUM_YEARLY_PRICE_ID=price_platinum_yearly_id_here

# Black Plan
VITE_STRIPE_BLACK_MONTHLY_PRICE_ID=price_black_monthly_id_here
VITE_STRIPE_BLACK_YEARLY_PRICE_ID=price_black_yearly_id_here

# Optional: Stripe Pricing Table ID (if using embedded pricing table)
# VITE_STRIPE_PRICING_TABLE_ID=prctbl_your_pricing_table_id_here

# ===== Netlify Functions Environment Variables =====
# Note: These should be set in Netlify Dashboard, not in .env
# STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# SITE_URL=https://your-site.netlify.app

# ===== Lemon Squeezy Configuration (Netlify Functions only) =====
# Note: These should be set in Netlify Dashboard, not in .env
# All Lemon Squeezy processing runs server-side via Netlify Functions
# LEMONSQUEEZY_API_KEY=eyJ_your_api_key_here
# LEMONSQUEEZY_STORE_ID=12345
# LEMONSQUEEZY_VARIANT_ID_STANDARD_GLOBAL=67890
# LEMONSQUEEZY_VARIANT_ID_STANDARD_GLOBAL_TRIAL=67891
# LEMONSQUEEZY_VARIANT_ID_PREMIUM=67890            # 月額（no trial）優先名
# LEMONSQUEEZY_VARIANT_ID_PREMIUM_TRIAL=67891      # 月額（trial）優先名
# LEMONSQUEEZY_VARIANT_ID_PREMIUM_YEARLY=67892     # 年額（no trial）
# LEMONSQUEEZY_VARIANT_ID_PREMIUM_YEARLY_TRIAL=67893  # 年額（trial）
# LEMONSQUEEZY_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Webhook (Netlify lemonsqueezyWebhook) は variant_id で plan_code を判定。custom_data は user_id のみ。

# ===== Supabase Configuration =====
# These should already be configured in your project
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ===== Developer lesson courses (Web) =====
# 本番ビルドで「開発者用テストコース」を表示する場合は true（管理者アカウントでも可）
# VITE_INCLUDE_DEV_LESSON_COURSES=true
# VITE_APP_ENV=development