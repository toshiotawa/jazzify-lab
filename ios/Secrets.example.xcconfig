// コピーして Secrets.xcconfig として保存し、値を埋めてください。
// cp Secrets.example.xcconfig Secrets.xcconfig
// Supabase Dashboard > Project Settings > API
// SUPABASE_ANON_KEY は anon public の JWT 1本のみ（ピリオドが2つ＝3セグメント）。
// service_role と連結しないこと。誤ると認証が失敗し OTP メールも届きません。

SUPABASE_HOST = your-project-ref.supabase.co
SUPABASE_ANON_KEY = your-supabase-anon-key
WEB_APP_HOST = jazzify.jp
