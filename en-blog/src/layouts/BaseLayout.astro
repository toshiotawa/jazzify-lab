---
import BlogAnalytics from '../components/BlogAnalytics.astro';
import BlogFooter from '../components/BlogFooter.astro';
import BlogHeader from '../components/BlogHeader.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage: string;
  ogType?: 'website' | 'article';
  robots?: string;
  publishedAt?: Date;
  updatedAt?: Date;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType = 'website',
  robots = 'index,follow,max-image-preview:large',
  publishedAt,
  updatedAt,
  jsonLd,
} = Astro.props;
const serializedJsonLd = jsonLd ? JSON.stringify(jsonLd).replaceAll('<', '\\u003c') : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Jazzify Blog" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}
    {updatedAt && <meta property="article:modified_time" content={updatedAt.toISOString()} />}
    <title>{title}</title>
    {jsonLd && <script is:inline type="application/ld+json" set:html={serializedJsonLd} />}
  </head>
  <body>
    <BlogHeader />
    <main class="site-shell page-main">
      <slot />
    </main>
    <BlogFooter />
    <BlogAnalytics />
  </body>
</html>
