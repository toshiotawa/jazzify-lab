# Cloudflare R2 / Wrangler 用のモック（ダミー値）
#
# 用途:
# - 値の形式の参考（32 桁 hex のアカウント ID など）
# - スクリプトやテストで「.env.r2 相当のキー名」だけ欲しいときのフィクスチャ
#
# 注意: 下記は実在しないアカウント／キーです。`.env.r2` または `env.r2` にそのままコピーしても R2 には繋がりません。
# 実運用は env.r2.example をコピーし、ダッシュボードの値を入れてください。

CF_ACCOUNT_ID=a0b1c2d3e4f5061728394a5b6c7d8e9f
R2_BUCKET=jazzify-assets-mock

# --s3 モード検証用のダミー（Wrangler OAuth のみなら不要）
CF_ACCESS_KEY=MOCK_R2_ACCESS_KEY_ID_32CH_LONG____
CF_SECRET_KEY=mock_r2_secret_key_for_local_fixture_only_not_real
